Authorization: Bearer {{authToken}}

### 

# @name fetch_list_orders
GET {{baseUrl}}/orders?page=1
Content-Type: application/json
Authorization: Bearer {{authToken}}

### 

# @name fetch_recipient_addresses
GET {{baseUrl}}/addresses/bf04f25e-e62c-4124-896b-38d2a6c8a0d8
Content-Type: application/json
Authorization: Bearer {{authToken}}

### 

# @name edit_user
PUT {{baseUrl}}/users/edit
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "newUserCpf": "123.456.789.10",
  "newUserName": "Thobias de Souza Maciel"
}

### 

# @name deliver_package
PATCH {{baseUrl}}/orders/cfccb747-212b-467c-aff1-b926b3db6770/deliver
Authorization: Bearer {{authToken}}
Content-Type: multipart/form-data; boundary=BOUNDARY

--BOUNDARY
Content-Disposition: form-data; name="orderId"

cfccb747-212b-467c-aff1-b926b3db6770
--BOUNDARY
Content-Disposition: form-data; name="deliveredAt"

2026-02-18T10:30:00Z
--BOUNDARY
Content-Disposition: form-data; name="file"; filename="package.png"
Content-Type: image/png

< ./package.png
--BOUNDARY--

###

# @name list_of_orders
GET {{baseUrl}}/list-of-orders
Content-Type: application/json
Authorization: Bearer {{authToken}}

###

